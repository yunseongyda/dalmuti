# --- Python 관련 ---
# 파이썬 실행 시 생성되는 캐시 (컴파일된 파일들)
__pycache__/
*.py[cod]
*$py.class

# 가상환경 (Virtual Environments)
venv/
.venv/
env/
bin/
lib/

# --- VS Code 관련 ---
# VS Code 개인 설정 및 작업 공간 정보
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# --- 빌드 및 배포 관련 (PyInstaller 등) ---
# 아까 빌드할 때 생겼던 폴더들이야!
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- 기타 ---
# 운영체제 생성 파일
.DS_Store
Thumbs.db

# 로그 파일
*.log